        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "max without (instance, pod, endpoint, container) (speedtest_download_bits_per_second{job=~\"$job\"}) / 1000000",
